{
  "name": "@grafana/async-query-data",
  "version": "0.4.3",
  "description": "Async query support for Grafana",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "npm run bundle -- --watch --watch.onStart=\"npm run typecheck\"",
    "build": "npm run clean && npm run typecheck && npm run bundle",
    "bundle": "rollup -c rollup.config.ts --configPlugin esbuild",
    "clean": "rimraf ./dist ./compiled",
    "lint": "eslint --cache ./src",
    "typecheck": "tsc -p ./tsconfig.build.json",
    "test": "jest --notify --watch",
    "test:ci": "jest",
    "test:coverage": "jest --coverage"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "repository": "github:grafana/grafana-async-query-data-js",
  "author": "Grafana Labs <team@grafana.com> (https://grafana.com)",
  "license": "Apache-2.0",
  "dependencies": {
    "semver": "7.8.0",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@eslint/compat": "2.1.0",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@grafana/data": "13.1.0",
    "@grafana/eslint-config": "9.0.0",
    "@grafana/runtime": "13.1.0",
    "@grafana/tsconfig": "2.1.0",
    "@grafana/ui": "13.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@stylistic/eslint-plugin-ts": "4.4.1",
    "@swc/core": "1.15.33",
    "@swc/jest": "0.2.39",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/react-hooks": "8.0.1",
    "@types/jest": "30.0.0",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@types/semver": "7.7.1",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "esbuild": "^0.28.0",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "identity-obj-proxy": "3.0.0",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "node-notifier": "10.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "rimraf": "6.1.3",
    "rollup": "4.60.3",
    "rollup-plugin-dts": "6.4.1",
    "rollup-plugin-esbuild": "6.2.1",
    "rollup-plugin-node-externals": "9.0.1",
    "typescript": "5.9.3"
  },
  "packageManager": "npm@11.18.0",
  "overrides": {
    "immutable": "5.1.9",
    "eslint-plugin-react": {
      "eslint": "$eslint"
    },
    "eslint-plugin-react-hooks": {
      "eslint": "$eslint"
    },
    "eslint-plugin-jsdoc": {
      "eslint": "$eslint"
    },
    "@testing-library/react-hooks": {
      "react": "$react",
      "react-dom": "$react-dom",
      "@types/react": "$@types/react"
    }
  },
  "engines": {
    "node": ">=24",
    "npm": ">=11.12.1"
  }
}
